    "@nestjs/terminus": "^10.2.0",
    "bullmq": "^5.12.0",
    "ioredis": "5.10.1",
    "nanoid": "^3.3.7",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "undici": "^6.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "dependency-cruiser": "^16.3.0",
